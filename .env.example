# Supabase / Postgres
# Pooled (port 6543) — dipakai oleh app saat runtime di Vercel serverless
DATABASE_URL="postgresql://postgres.xxx:[password]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct (port 5432) — dipakai Prisma untuk migrate / db push
DIRECT_URL="postgresql://postgres.xxx:[password]@aws-0-xxx.pooler.supabase.com:5432/postgres"

# Login gate. Kalau ketiganya kosong, app tidak punya auth (semua publik).
# Set ketiganya di Vercel env vars supaya dashboard dilindungi password.
# AUTH_SECRET: random string untuk HMAC signing. Generate via:
#   openssl rand -hex 32
AUTH_USERNAME="admin"
AUTH_PASSWORD="ganti-passwordnya"
AUTH_SECRET="paste-output-openssl-rand-hex-32-disini"

# Note: Repliz, OpenAI, OpenRouter, and Claude API keys are stored in the
# Settings table and managed via the /settings UI page, not in env vars.
